{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Personal Update Build (Windows)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/build-windows.ps1",
        "-PersonalUpdate"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Clean Portable Build (Windows)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "scripts/build-windows.ps1"
      ],
      "problemMatcher": []
    }
  ]
}
